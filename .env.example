# ============================================================
# AgenticAI Project — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is already in .gitignore.
# ============================================================

# ---------- LLM API Keys ----------
# Get your free Gemini key at: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Get your free Groq key at: https://console.groq.com/
# Used as a fast fallback if Gemini is slow or unavailable.
GROQ_API_KEY=your_groq_api_key_here

# ---------- Model Selection ----------
# Recommended defaults — change only if you know what you're doing.
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama3-8b-8192

# ---------- Lip Sync Settings ----------
# Path to the SadTalker directory (cloned separately).
# Leave as-is unless you cloned it to a different location.
SADTALKER_PATH=./SadTalker

# ---------- Optional: Paths ----------
# Override output/temp directories if needed (defaults work for most setups).
# OUTPUTS_DIR=./data/outputs
# TEMP_DIR=./data/temp
# STATE_VERSIONS_DIR=./data/state_versions
# BGM_DIR=./assets/bgm
